<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="32dp">

    <View android:layout_width="0dp" android:layout_height="48dp" />

    <!-- Logo mark -->
    <TextView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:gravity="center"
        android:text="\u25C9"
        android:textSize="40sp"
        android:textColor="@color/accent"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NANDA"
        android:textSize="26sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Magic Trackpad"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:letterSpacing="0.15"
        android:layout_marginBottom="48dp" />

    <!-- Status -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Checking setup..."
        android:textSize="15sp"
        android:textColor="@color/accent"
        android:layout_marginBottom="28dp" />

    <!-- Steps card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:padding="24dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/step1_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bluetooth Permissions"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface_light"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/step2_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bluetooth Enabled"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface_light"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/step3_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ready to Connect"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

    <!-- Action button -->
    <TextView
        android:id="@+id/action_button"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center"
        android:text="Continue"
        android:textSize="15sp"
        android:textColor="@color/bg_dark"
        android:textStyle="bold"
        android:background="@color/accent"
        android:letterSpacing="0.05"
        android:layout_marginBottom="24dp" />

    <!-- Last device info -->
    <TextView
        android:id="@+id/last_device_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="@color/text_dim"
        android:visibility="gone" />

</LinearLayout>
</ScrollView>
